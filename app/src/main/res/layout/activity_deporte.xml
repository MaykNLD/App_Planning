<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".lista.Dia">

    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">
            <TextView
                android:gravity="start"
                android:id="@+id/borrarNotaDeporte"
                android:drawableStart="@drawable/ic_borrar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="15dp">
            <TextView
                android:id="@+id/notaDeporte"
                android:hint="@string/notaDeporte"
                android:textSize="25dp"
                android:textColor="@color/colorCuarto"
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </androidx.appcompat.widget.LinearLayoutCompat>

        <EditText
            android:id="@+id/tituloEt"
            android:hint="@string/tipoEntrenamiento"
            android:textSize="25sp"
            android:textStyle="bold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:autofillHints="" />
        <EditText
            android:id="@+id/descripcionEt"
            android:hint="@string/rutina"
            android:textSize="25sp"
            android:minHeight="250dp"
            android:gravity="start"
            android:textStyle="bold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:autofillHints="" />

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:padding="1dp"
            android:paddingStart="15dp">

            <Button
                android:id="@+id/btnCalendarioDeporte"
                android:text="@string/btnCalendario"
                app:icon="@drawable/ic_bcalendario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/fechaDeporte"
                android:hint="@string/fecha"
                android:textSize="20sp"
                android:layout_marginStart="15dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:padding="1dp"
            android:paddingStart="15dp">

            <Button
                android:id="@+id/btnHoraDeporteXml"
                android:text="@string/btnHora"
                app:icon="@drawable/ic_hour"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/horaDeporteXml"
                android:hint="@string/hora"
                android:textSize="20sp"
                android:layout_marginStart="15dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </androidx.appcompat.widget.LinearLayoutCompat>

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingStart="15dp"
            android:padding="15dp">
            <Button
                android:id="@+id/btnGuardar"
                android:text="@string/btnGuardar"
                app:icon="@drawable/ic_guardar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </androidx.appcompat.widget.LinearLayoutCompat>

    </androidx.appcompat.widget.LinearLayoutCompat>
</ScrollView>