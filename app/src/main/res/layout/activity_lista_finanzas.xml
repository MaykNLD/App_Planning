<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorTercero"
    android:padding="16dp"
    tools:context=".lista.ListaFinanzas">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/MenuFinanzas">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/piePagina"
            android:text="@string/encabezado"
            android:textSize="32dp"
            android:textColor="@color/colorCuarto"/>
        <ImageButton
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_menu"
            android:id="@+id/btnMenuFinanzasDespegable"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            app:tint="@color/colorCuarto"
            android:background="?attr/selectableItemBackgroundBorderless"/>
    </RelativeLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewFinanzas"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/MenuFinanzas"/>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnNuevaNotaFinanzas"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/colorCuarto"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:src="@drawable/ic_nueva_nota"/>

</RelativeLayout>